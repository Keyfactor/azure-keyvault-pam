{
  "$schema": "https://keyfactor.github.io/integration-manifest-schema.json",
  "integration_type": "pam",
  "name": "Azure Key Vault PAM Provider",
  "status": "prototype",
  "support_level": "kf-community",
  "update_catalog": false,
  "link_github": false,
  "description": "The Azure Key Vault PAM Provider allows for the retrieval of stored credentials from an Azure Key Vault secret. A valid Key Vault URL is required. Currently in dev, a work in progress,",
  "about": {
    "pam": {
      "providerName": "Azure Key Vault PAM Provider",
      "assemblyName": "azure-keyvault-pam",
      "dbName": "Azure-KeyVault",
      "fullyQualifiedClassName": "Keyfactor.Extensions.Pam.AzureKeyVault.KeyVaultPam",
      "pam_types": {
        "Azure-KeyVault": {
          "Name": "Azure-KeyVault",
          "Parameters": [
            {
              "Name": "KeyVaultUri",
              "DisplayName": "Key Vault URI",
              "DataType": 1,
              "InstanceLevel": false
            },
            {
              "Name": "AuthorityHost",
              "DisplayName": "Authority Host",
              "DataType": 1,
              "InstanceLevel": false
            },
            {
              "Name": "SecretId",
              "DisplayName": "Secret ID",
              "DataType": 1,
              "InstanceLevel": true
            }
          ]
        },
        "Azure-KeyVault-ServicePrincipal": {
          "Name": "Azure-KeyVault-ServicePrincipal",
          "Parameters": [
            {
              "Name": "KeyVaultUri",
              "DisplayName": "Key Vault URI",
              "DataType": 1,
              "InstanceLevel": false
            },
            {
              "Name": "AuthorityHost",
              "DisplayName": "Authority Host",
              "DataType": 1,
              "InstanceLevel": false
            },
            {
              "Name": "TenantId",
              "DisplayName": "Tenant ID",
              "DataType": 1,
              "InstanceLevel": false
            },
            {
              "Name": "ClientId",
              "DisplayName": "Client ID",
              "DataType": 1,
              "InstanceLevel": false
            },
            {
              "Name": "ClientSecret",
              "DisplayName": "ClientSecret",
              "DataType": 2,
              "InstanceLevel": false
            },
            {
              "Name": "SecretId",
              "DisplayName": "Secret ID",
              "DataType": 1,
              "InstanceLevel": true
            }
          ]
        }
      }
    }
  },
  "release_dir": "azure-keyvault-pam/bin/Release/netstandard2.0"
}

